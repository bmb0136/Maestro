+package com.shuzijun.plantumlparser.cli.options.exclude;
+
+import com.shuzijun.plantumlparser.cli.options.CliOption;
+import com.shuzijun.plantumlparser.core.ParserConfig;
+import org.apache.commons.cli.CommandLine;
+import org.apache.commons.cli.Option;
+
+import java.util.Arrays;
+
+public class AddExcludeOption implements CliOption {
+
+    private static final String NAME = "e";
+    private static final String LONG_NAME = "exclude";
+    private static final String DESCRIPTION = "Regex to exclude specific classes";
+
+    private final Option option;
+
+    public AddExcludeOption() {
+        option = new Option(NAME, LONG_NAME, true, DESCRIPTION);
+    }
+
+    @Override
+    public Option getOption() {
+        return option;
+    }
+
+    @Override
+    public ParserConfig updateConfig(ParserConfig parserConfig, CommandLine cmd) {
+        return Arrays.stream(cmd.getOptions())
+                .filter(option -> option.getOpt().equalsIgnoreCase(NAME))
+                .findAny()
+                .map(option -> {
+                    for (String val : cmd.getOptionValues(option)) {
+                        parserConfig.addExcludeClassRegex(val);
+                    }
+                    return parserConfig;
+                })
+                .orElse(parserConfig);
+    }
+}
