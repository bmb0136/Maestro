<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<VBox fx:id="root" prefHeight="360.0" prefWidth="720.0" xmlns="http://javafx.com/javafx/21.0.3-internal" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <ToolBar prefHeight="40.0" prefWidth="200.0" VBox.vgrow="NEVER" />
      <HBox VBox.vgrow="ALWAYS">
         <children>
            <ScrollPane hbarPolicy="NEVER" style="-fx-background-color: transparent;" vbarPolicy="NEVER">
               <content>
                  <AnchorPane fx:id="notesPane" prefWidth="100.0" />
               </content>
            </ScrollPane>
            <ScrollPane style="-fx-background-color: transparent;" HBox.hgrow="ALWAYS" />
         </children>
      </HBox>
   </children>
</VBox>
